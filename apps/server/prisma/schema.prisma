// Context Studio metadata store.
//
// Git (.context-repo/) is the source of truth for context *content*.
// This database holds the metadata Git models poorly: PR lifecycle + routing,
// the attribution index, the freshness/TTL state machine, and the agent
// "blast radius" mappings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// The connection to the external context store this instance manages.
// meva holds at most a disposable working copy; the canonical content lives at
// `location`. A single active workspace is supported (id = "default").
model Workspace {
  id            String   @id @default("default")
  sourceType    String // primary source: "local" | "remote" (backs current editing)
  location      String // primary source location
  identityName  String
  identityEmail String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sources       WorkspaceSource[]
}

// A typed source in the workspace (context / skills / memory / custom). Each can
// be its own repo or share a location (unified repo).
model WorkspaceSource {
  id          String @id @default(cuid())
  kind        String
  sourceType  String // "local" | "remote"
  location    String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
}

// Hashed API key for an autonomous agent. The raw key is shown once at
// creation and never stored — only its sha256. Used to authenticate
// agent-submit so agents can't be impersonated.
model ApiKey {
  id        String   @id @default(cuid())
  agentId   String
  hashedKey String   @unique
  label     String?
  createdAt DateTime @default(now())
}

model Author {
  id        String   @id
  kind      String // "human" | "agent"
  name      String
  role      String? // display title, e.g. "Compliance Officer"
  email     String?  @unique // for SSO identity matching
  accessRole String  @default("reviewer") // AccessRole: owner | reviewer | viewer
  prs       Pr[]
  reviews   Reviewer[]
  attributions AttributionEntry[]
}

model Pr {
  id          String   @id
  title       String
  description String
  status      String // PrStatus
  origin      String // "ui" | "agent"
  documentPath String
  // The transparent Git draft branch backing this PR. The UI never sees this.
  draftBranch String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   Author @relation(fields: [authorId], references: [id])
  authorId String

  reviewers   Reviewer[]
  blastEntries BlastEntry[]
}

model Reviewer {
  id        String   @id @default(cuid())
  decision  String // "pending" | "approved" | "changes_requested"
  required  Boolean  @default(true)
  decidedAt DateTime?

  pr       Pr     @relation(fields: [prId], references: [id], onDelete: Cascade)
  prId     String
  author   Author @relation(fields: [authorId], references: [id])
  authorId String

  @@unique([prId, authorId])
}

model BlastEntry {
  id        String @id @default(cuid())
  agentId   String
  agentName String
  purpose   String
  severity  String // "low" | "medium" | "high"
  reason    String

  pr   Pr     @relation(fields: [prId], references: [id], onDelete: Cascade)
  prId String
}

// Per-block freshness, tracked by the governance state machine (Module 4).
model BlockFreshness {
  id             String   @id @default(cuid())
  documentPath   String
  blockKey       String
  text           String
  state          String // FreshnessState: fresh | stale | expired | conflicted
  lastReviewedAt DateTime
  ttlDays        Int
  staleAt        DateTime

  @@unique([documentPath, blockKey])
}

// A review ticket auto-opened by the TTL worker when a block goes stale, or by
// the conflict detector when two open PRs touch the same block.
model ReviewTicket {
  id           String   @id @default(cuid())
  documentPath String
  blockKey     String
  blockText    String
  reason       String
  state        String   @default("open") // open | resolved
  createdAt    DateTime @default(now())
  assigneeId   String?

  @@unique([documentPath, blockKey, reason])
}

// The attribution index: maps a normalized block of text within a document to
// the author + PR that merged it. Powers the non-technical "Attribution Gutter".
model AttributionEntry {
  id           String   @id @default(cuid())
  documentPath String
  // Normalized text key of the logical block (see SemanticDiffService.blockKey).
  blockKey     String
  mergedAt     DateTime
  prId         String
  prTitle      String

  author   Author @relation(fields: [authorId], references: [id])
  authorId String

  @@index([documentPath, blockKey])
}
